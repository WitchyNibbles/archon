# Archon Environment Configuration
# In this repo: copy to .env and fill in values (`cp .env.example .env`).
# In a consuming project (archon installed as a dependency): copy to .env.archon
# at the project root — the loader checks ./.env.archon first, then ./.env.

# PostgreSQL connection string for Archon state store
ARCHON_CORE_DATABASE_URL=postgresql://archon:archon-local-password@127.0.0.1:5432/archon
ARCHON_POSTGRES_DB=archon
ARCHON_POSTGRES_USER=archon
ARCHON_POSTGRES_PASSWORD=archon-local-password
ARCHON_POSTGRES_PORT=5432
ARCHON_DOCKER_CONTAINER_NAME=archon-postgres
ARCHON_RUNTIME_MODE=auto
ARCHON_RUNTIME_PROFILE=local-docker

ARCHON_EMBEDDING_MODEL=archon-local-hash-1536

# Workspace and project identity
ARCHON_WORKSPACE_SLUG=default
ARCHON_WORKSPACE_NAME="Default Workspace"
ARCHON_PROJECT_SLUG=archon
ARCHON_PROJECT_NAME=archon
ARCHON_PROJECT_REPO_PATH=/absolute/path/to/repo

# Review identity
ARCHON_REVIEW_IDENTITY_BINDINGS=.archon/review-identity-bindings.json
ARCHON_REVIEW_IDENTITY_FIXTURES=.archon/review-identity-adapter.fixture.json
ARCHON_REVIEW_IDENTITY_ADAPTER_MODULE=./archon/review-identity-adapter.ts

# Agentic loop: context handoff thresholds (optional)
# The managed loop records a context sample each turn and transitions
# normal -> warning -> handoff_required -> hard_stop at these percentages.
# Values are percentages of the context window (0-100).
ARCHON_CONTEXT_WARNING_PCT=60
ARCHON_CONTEXT_HANDOFF_PCT=70
ARCHON_CONTEXT_HARD_STOP_PCT=80

# Agentic loop: context monitor mode (optional, default enforce)
#   enforce — apply state transitions as computed (handoff_required gates the loop)
#   observe — downgrade handoff_required -> warning (record data, do not gate);
#             hard_stop is never downgraded
ARCHON_CONTEXT_MONITOR=enforce

# Agentic loop: specialist subagent spawning (optional, default enabled)
#   disabled — reject all archon_spawn_subtask requests
ARCHON_SUBAGENTS=enabled

# Agentic loop: multi-agent debate gate (optional, default enabled)
#   disabled — shouldDebate() returns false for every trigger
ARCHON_DEBATE_GATE=enabled

# Review-floor reduction (optional, default OFF / unset)
#   When "1" or "true", a genuinely trivial task may close on a single `reviewer`
#   instead of the full reviewer+security_reviewer+qa_engineer trio — but ONLY when
#   its class is opt-out (docs_only, state_sync, memory_curation, scaffold_only) AND
#   its entire write scope is review-safe (no control-layer or repo-indexed paths).
#   Every reduction writes a durable review_floor_reductions provenance row. Leave
#   unset to require the full trio for all tasks. See docs/proposals/option-b-review-floor.md.
# ARCHON_REVIEW_FLOOR_REDUCTION=1

# MCP server port (optional, default 3000)
ARCHON_MCP_PORT=3000

# UI server port (optional, default 3001)
ARCHON_UI_PORT=3001

# Grafana integration (optional)
# ARCHON_GRAFANA_URL=https://grafana.example.com
# ARCHON_GRAFANA_TOKEN=your-grafana-service-account-token
# ARCHON_GRAFANA_LOGS_DATASOURCE_UID=your-logs-datasource-uid
ARCHON_GRAFANA_URL=
ARCHON_GRAFANA_TOKEN=
ARCHON_GRAFANA_USERNAME=
ARCHON_GRAFANA_PASSWORD=
ARCHON_GRAFANA_ORG_ID=
ARCHON_GRAFANA_LOGS_DATASOURCE_UID=
ARCHON_GRAFANA_LOKI_TENANT_ID=
ARCHON_GRAFANA_TIMEOUT_MS=15000
