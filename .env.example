# Archon Environment Configuration
# Copy to .env.archon and fill in values

# PostgreSQL connection string for Archon state store
ARCHON_CORE_DATABASE_URL=postgresql://archon:archon@localhost:5432/archon

# Qdrant vector DB for memory search
ARCHON_QDRANT_URL=http://localhost:6333
ARCHON_QDRANT_COLLECTION=archon_memory

# Workspace and project identity
ARCHON_WORKSPACE_SLUG=default
ARCHON_PROJECT_SLUG=my-project

# MCP server port (optional, default 3000)
ARCHON_MCP_PORT=3000

# UI server port (optional, default 3001)
ARCHON_UI_PORT=3001
