# Archon Environment Configuration
# NEVER use these placeholder values in production — they are non-functional
# defaults for local development only.  Always set a strong, unique password
# before connecting to any non-throwaway database instance.
#
# Usage:
#   In this repo (development):             cp .env.example .env
#   In a consuming project (archon installed as a dependency):
#                                           cp .env.example .env.archon
#   The dot-env loader checks ./.env.archon first, then ./.env.
#
# Section layout:
#   REQUIRED             — set these before starting a DB-backed archon runtime.
#   DATABASE CONVENIENCE — docker-compose helper vars (compose the DB URL).
#   RUNTIME & MODE
#   CONTEXT / AGENTIC LOOP
#   PORTS
#   EMBEDDING
#   REVIEW IDENTITY
#   GRAFANA (optional observability)
#   FORGE / SECRETS
#   ADVANCED / INTERNAL

# ===========================================================================
# REQUIRED — set these for a DB-backed archon runtime
# ===========================================================================

# PostgreSQL connection string for archon's state store.
#
# TWO MODES:
#   DB-backed (recommended): a reachable Postgres is the workflow completion
#     authority. Start it with `npm run setup:local` (Docker), then run
#     `npm run doctor` to verify.
#   Local-only: COMMENT OUT the line below to run without a database. The
#     agent workflow still works from local .archon/ state; only the
#     Postgres-backed runtime proof (workflow-proof command) is unavailable.
#
# NOTE: if this URL is set but Postgres is NOT reachable, DB commands fail
# with a connection error. Either start Postgres, fix the URL, or comment
# this line out.
ARCHON_CORE_DATABASE_URL=postgresql://archon:CHANGEME_SET_A_STRONG_PASSWORD_NEVER_USE_IN_PRODUCTION@127.0.0.1:5432/archon

# Workspace identifier — scopes multiple projects under one archon instance.
# Default: default
ARCHON_WORKSPACE_SLUG=default
ARCHON_WORKSPACE_NAME="Default Workspace"

# Project identifier — required by most runtime commands (status, daemon,
# loop, workflow-proof, etc.).  Set this to a short slug for your repo.
ARCHON_PROJECT_SLUG=archon
ARCHON_PROJECT_NAME=archon

# Absolute path to the project repository root (used by retrieval/indexing).
ARCHON_PROJECT_REPO_PATH=/absolute/path/to/repo

# ===========================================================================
# DATABASE CONVENIENCE — docker-compose only
# Used by scripts/setup-archon.sh to compose ARCHON_CORE_DATABASE_URL from
# individual parts.  NOT consumed by the archon runtime directly.
# ===========================================================================

ARCHON_POSTGRES_DB=archon
ARCHON_POSTGRES_USER=archon
ARCHON_POSTGRES_PASSWORD=CHANGEME_SET_A_STRONG_PASSWORD_NEVER_USE_IN_PRODUCTION
ARCHON_POSTGRES_PORT=5432
ARCHON_DOCKER_CONTAINER_NAME=archon-postgres

# ===========================================================================
# RUNTIME & MODE
# ===========================================================================

# Runtime execution mode (optional).
#   auto (default) — derive mode from ARCHON_RUNTIME_PROFILE.
#   docker | native | managed — explicit override.
ARCHON_RUNTIME_MODE=auto

# Runtime profile string (optional). Used when ARCHON_RUNTIME_MODE=auto.
# Default: local-docker
ARCHON_RUNTIME_PROFILE=local-docker

# Override the runtime data root (optional).
# The encrypted secret store lives at <dataRoot>/secrets/secrets.enc.
# Default: platform-specific user data directory OUTSIDE the repo.
#   Linux:   ~/.local/share/archon/<project-slug>
#   macOS:   ~/Library/Application Support/archon/<project-slug>
#   Windows: %LOCALAPPDATA%\archon\<project-slug>
# ARCHON_RUNTIME_DATA_ROOT=/absolute/path/outside/repo

# Fallback data root for prune/sweep output files (optional).
# Default: current working directory at command time.
# ARCHON_DATA_ROOT=/absolute/path

# ===========================================================================
# CONTEXT / AGENTIC LOOP
# ===========================================================================

# Context-window thresholds (optional).
# Values are percentages of the model context window (0-100).
# The managed loop records a context sample each turn and transitions:
#   normal -> warning -> handoff_required -> hard_stop
# at the thresholds below.
ARCHON_CONTEXT_WARNING_PCT=60
ARCHON_CONTEXT_HANDOFF_PCT=70
ARCHON_CONTEXT_HARD_STOP_PCT=80

# Context monitor mode (optional).
#   enforce (default) — apply state transitions; daemon auto-respawns when
#             handoff_required or hard_stop is reached.
#   observe — KILL SWITCH: suppress daemon auto-respawn; sample without
#             resetting. handoff_required is downgraded to warning;
#             hard_stop is NEVER downgraded.
#
# Uncomment to disable daemon auto-respawn:
# ARCHON_CONTEXT_MONITOR=observe

# Per-task daemon respawn budget (optional).
# Caps how many times the daemon may auto-respawn for one task before it
# blocks with recovery_required. Integer in [1, 50]; outside that range,
# non-integer, or absent/empty falls back to the default of 8.
# Pairs with ARCHON_CONTEXT_MONITOR=enforce — the kill switch disables
# respawn entirely; this caps it when enforce is active.
# ARCHON_MAX_RESPAWNS_PER_TASK=8

# Subagent spawning gate (optional).
#   enabled (default) | disabled — set to disabled to reject all
#                                   archon_spawn_subtask requests.
ARCHON_SUBAGENTS=enabled

# Multi-agent debate gate (optional).
#   enabled (default) | disabled — set to disabled to turn off debate triggers.
ARCHON_DEBATE_GATE=enabled

# Review-floor reduction (optional, default OFF / unset).
#   When "1" or "true", a genuinely trivial task may close on a single
#   `reviewer` instead of the full reviewer+qa_engineer+security_reviewer
#   trio — but ONLY when its class is opt-out (docs_only, state_sync,
#   memory_curation, scaffold_only) AND its entire write scope is review-safe
#   (no control-layer or repo-indexed paths). Every reduction writes a durable
#   provenance row. Leave unset to require the full trio for all tasks.
#   See docs/proposals/option-b-review-floor.md.
# ARCHON_REVIEW_FLOOR_REDUCTION=1

# ===========================================================================
# PORTS
# ===========================================================================

# MCP server listening port (optional). Default: 3000
ARCHON_MCP_PORT=3000

# UI / dashboard server listening port (optional). Default: 3001
ARCHON_UI_PORT=3001

# ===========================================================================
# EMBEDDING
# ===========================================================================

# Embedding model identifier (optional).
# Default: archon-local-hash-1536 (fast, local, deterministic).
# Set to an Anthropic/Voyage model slug when using a real embedding provider;
# also set ARCHON_EMBEDDING_PROVIDER_MODULE.
ARCHON_EMBEDDING_MODEL=archon-local-hash-1536

# ===========================================================================
# REVIEW IDENTITY
# ===========================================================================

# Paths to review-identity config files (optional).
# See docs/archon-agent-team.md for the review-identity system design.
ARCHON_REVIEW_IDENTITY_BINDINGS=.archon/review-identity-bindings.json
ARCHON_REVIEW_IDENTITY_FIXTURES=.archon/review-identity-adapter.fixture.json
ARCHON_REVIEW_IDENTITY_ADAPTER_MODULE=./archon/review-identity-adapter.ts

# ===========================================================================
# GRAFANA (optional observability integration)
# ===========================================================================

# See docs/forge-operator-runbook.md §5 for the full Grafana setup guide.
# All credential values are PLACEHOLDERS. Never commit a real token or password.

# ARCHON_GRAFANA_URL=https://grafana.example.com
# ARCHON_GRAFANA_TOKEN=your-grafana-service-account-token
# ARCHON_GRAFANA_LOGS_DATASOURCE_UID=your-logs-datasource-uid
ARCHON_GRAFANA_URL=
ARCHON_GRAFANA_TOKEN=
ARCHON_GRAFANA_USERNAME=
ARCHON_GRAFANA_PASSWORD=
ARCHON_GRAFANA_ORG_ID=
ARCHON_GRAFANA_LOGS_DATASOURCE_UID=
ARCHON_GRAFANA_LOKI_TENANT_ID=
ARCHON_GRAFANA_TIMEOUT_MS=15000

# ===========================================================================
# FORGE / SECRETS
# ===========================================================================

# See docs/forge-operator-runbook.md for the full operator runbook.
# All values below are PLACEHOLDERS. Never commit a real secret.

# Secret-manager backend selector (optional, default: encrypted_file).
# encrypted_file is the only backend implemented today; any other value errors.
ARCHON_SECRETS_BACKEND=encrypted_file

# Master key that unlocks the encrypted secret store.
# MUST be exactly 64 hexadecimal characters (32 bytes).
# Generate: openssl rand -hex 32
# Store in a password manager / OS keychain / CI secret store — NOT in a
# tracked file.  Read lazily then scrubbed from the process environment.
# Required only when you store secrets (e.g. the Forge API provider key).
# ARCHON_SECRETS_MASTER_KEY=REPLACE_WITH_64_HEX_CHARS_generate_with_openssl_rand_hex_32

# API image provider opt-in (switch 1 of 2).
# The OpenAI gpt-image provider is OFF unless this equals exactly "true".
# CI always falls back to placeholder.
# ARCHON_FORGE_API_PROVIDER_ENABLED=true

# API image provider spend cap (switch 2 of 2). Run-level max generations.
# Deny-by-default: absent / zero / negative / non-integer => denied.
# Positive integer only. The API key itself is stored in the secret manager
# under the ref forge.openai_api_key (via `archon secret set`), NOT here.
# ARCHON_FORGE_API_SPEND_CAP=25

# ===========================================================================
# ADVANCED / INTERNAL
# These are typically set by daemon scripts or automation, not operators.
# Most operators do NOT need to set any of the following vars.
# ===========================================================================

# Override the model context window size in tokens (optional).
# Default: model-reported value (used by the context monitor).
# Set this only if your model reports a different window size than archon
# expects (e.g. when running a custom or local model).
# ARCHON_MODEL_CONTEXT_TOKENS=200000

# Obsidian knowledge-base integration (optional).
# ARCHON_OBSIDIAN_VAULT_PATH=/absolute/path/to/vault
# ARCHON_OBSIDIAN_TIMEZONE=UTC
