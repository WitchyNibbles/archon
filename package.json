  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/admin.ts",
    "archon": "node --experimental-strip-types src/admin/archon.ts",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "check:quality": "tsc --noEmit && npm test",
    "check:workflow": "bash scripts/check-archon-workflow.sh",
    "check:happy-path": "bash scripts/check-archon-happy-path.sh",
    "check:coverage": "node --experimental-strip-types scripts/check-coverage.ts",
    "setup:local": "docker compose up -d archon-postgres",
    "migrate": "tsx src/admin.ts migrate",
    "health": "tsx src/admin.ts health",
    "bootstrap": "tsx src/admin.ts bootstrap-project",
    "verify:setup": "tsx src/admin.ts verify-setup",
    "doctor": "tsx src/admin.ts doctor",
    "status": "tsx src/admin.ts status",
    "ops": "tsx src/admin.ts ops",
    "mcp": "tsx src/mcp/server.ts",
    "install:project": "tsx src/install/cli.ts",
    "scaffold:workflow": "node --experimental-strip-types src/install/cli.ts scaffold-workflow --target .",
    "archon:autopilot-status": "node --experimental-strip-types src/archon/autopilot-status.ts",
    "archon:loop": "node --experimental-strip-types src/admin/archon.ts loop --format text",
    "verify:release-overlay": "bash scripts/verify-release-overlay.sh",
    "grafana:mcp": "tsx src/grafana/mcp-server.ts",
    "evals:orchestration": "node --experimental-strip-types src/evals/orchestration-baseline.ts",
