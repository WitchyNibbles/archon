node_modules/
dist/
.env
.env.archon
*.local

# Runtime artifacts
.archon/work/daemon/
.archon/work/briefs/
.archon/work/plans/
.archon/work/tasks/
.archon/work/reviews/
.archon/work/council/
.archon/work/proofs/
.archon/work/context-guard.json
.archon/work/touched-paths.jsonl
.archon/work/subagent-stops.jsonl

# Keep the directory skeletons
!.archon/work/briefs/.gitkeep
!.archon/work/plans/.gitkeep
!.archon/work/tasks/.gitkeep
!.archon/work/reviews/.gitkeep
!.archon/work/council/.gitkeep
!.archon/work/proofs/.gitkeep
!.archon/work/daemon/.gitkeep

# Generated output
graphify-out/
coverage/

# Forge web workspace — toolchain outputs never tracked
web/node_modules/
web/dist/
# Forge generated assets (runtime-produced binaries/data for the UI).
# The directory skeleton (web/src/assets/generated/.gitkeep) IS tracked;
# everything inside the directory at build time is NOT.
web/src/assets/generated/*
!web/src/assets/generated/.gitkeep

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db
