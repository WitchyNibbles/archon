node_modules/
dist/
.env
.env.archon
*.local

# Operator-local review-identity authority (live config — NEVER commit to the
# shared package repo; consumers/operators own these per CLAUDE.md live-state rule).
# The shipped TEMPLATES under .archon/templates/ ARE tracked; these live files are not.
.archon/review-identity-adapter.ts
.archon/review-identity-bindings.json
.archon/review-identity-adapter.fixture.json

# Runtime artifacts
.archon/work/daemon/
# .archon/ACTIVE is ephemeral runtime-pointer state — regenerated by the runtime /
# reconcile / init-task and read from the working tree by the hooks. Tracking it
# left a stale `active` pointer in git that imposed a bogus active-task scope lock
# on fresh clones, so it is kept out of version control.
.archon/ACTIVE
# Playwright browser binaries + run artifacts (created by archon:setup:playwright).
# Chromium is hundreds of MB; the MCP configs under .archon/playwright/ ARE tracked.
.archon/playwright/browsers/
.archon/work/artifacts/
.archon/work/briefs/
.archon/work/plans/
.archon/work/tasks/
.archon/work/reviews/
.archon/work/council/
.archon/work/proofs/
.archon/work/context-guard.json
.archon/work/touched-paths.jsonl
.archon/work/subagent-stops.jsonl

# Keep the directory skeletons
!.archon/work/briefs/.gitkeep
!.archon/work/plans/.gitkeep
!.archon/work/tasks/.gitkeep
!.archon/work/reviews/.gitkeep
!.archon/work/council/.gitkeep
!.archon/work/proofs/.gitkeep
!.archon/work/daemon/.gitkeep

# Generated output
graphify-out/
coverage/

# Forge web workspace — toolchain outputs never tracked
web/node_modules/
web/dist/
# Forge generated assets (runtime-produced binaries/data for the UI).
# The directory skeleton (web/src/assets/generated/.gitkeep) IS tracked;
# everything inside the directory at build time is NOT.
web/src/assets/generated/*
!web/src/assets/generated/.gitkeep

# Secret store — guards the Pillar B encrypted-file backend data root at dataRoot/secrets/
# (CC-16). This rule is anchored to the repo-relative dataRoot/secrets/ path specifically; a
# runtime data root configured to live ELSEWHERE on disk is naturally outside the repo and
# therefore not git-trackable. Encrypted secret material must never be committed (P5-S3).
dataRoot/secrets/

# Prune-orphans backups — the `archon prune-orphans --confirm` verb writes a pre-delete
# JSON snapshot of the removed task/run rows here (default <dataRoot>/prune-backups/, which
# can resolve to the repo root). These are local recovery artifacts of internal runtime
# state and must never be committed.
prune-backups/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db
